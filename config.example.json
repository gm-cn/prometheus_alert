{
  "server": {
    "port": 8080
  },
  "kafka": {
    "brokers": ["localhost:9092"],
    "topic": "alerts",
    "username": "",
    "password": "",
    "mechanism": "PLAIN",
    "protocol": "PLAINTEXT",
    "timeout": "30s"
  },
  "log": {
    "level": "info",
    "filename": "logs/app.log",
    "maxSize": 100,
    "maxBackups": 3,
    "maxAge": 28,
    "compress": true
  },
  "prometheus": {
    "remoteUrl": "http://pre.cloudbee-api.jd.local/api/v1/event-strategy-main/list",
    "ruleFilePath": "/export/prometheus4/rule/alert.yml",
    "reloadUrl": "http://127.0.0.1:19093/-/reload",
    "syncInterval": "1m"
  }
}