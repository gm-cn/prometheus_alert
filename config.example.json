{
  "server": {
    "port": 8080
  },
  "kafka": {
    "brokers": ["localhost:9092"],
    "topic": "alerts",
    "username": "",
    "password": "",
    "mechanism": "PLAIN",
    "protocol": "PLAINTEXT",
    "timeout": "30s"
  },
  "log": {
    "level": "info",
    "filename": "logs/app.log",
    "maxSize": 100,
    "maxBackups": 3,
    "maxAge": 28,
    "compress": true
  },
  "prometheus": {
    "remoteUrl": "http://remote-prometheus:9090/api/v1/rules",
    "ruleFilePath": "/etc/prometheus/rules/alert.rules.yml",
    "reloadUrl": "http://localhost:9090/-/reload",
    "syncInterval": "5m"
  }
}